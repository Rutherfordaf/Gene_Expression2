    "# Publication quality PCA\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "import numpy as np\n",
    "\n",
    "# Extract PCA coordinates and condition labels\n",
    "pca_coords = pca_data.obsm['X_pca']\n",
    "conditions = pca_data.obs['condition'].values\n",
    "\n",
    "# Variance explained\n",
    "var_explained = pca_data.uns['pca']['variance_ratio'] * 100\n",
    "\n",
    "# Color and style config\n",
    "palette = {'Cancer': '#C0392B', 'Infection': '#2980B9'}\n",
    "markers = {'Cancer': 'o', 'Infection': 's'}\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "\n",
    "for condition, group in [('Infection', 'Infection'), ('Cancer', 'Cancer')]:\n",
    "    mask = conditions == condition\n",
    "    ax.scatter(\n",
    "        pca_coords[mask, 0],\n",
    "        pca_coords[mask, 1],\n",
    "        c=palette[condition],\n",
    "        marker=markers[condition],\n",
    "        s=45,\n",
    "        alpha=0.7,\n",
    "        edgecolors='white',\n",
    "        linewidths=0.4,\n",
    "        label=condition,\n",
    "        zorder=2 if condition == 'Cancer' else 1\n",
    "    )\n",
    "\n",
    "# Confidence ellipses\n",
    "from matplotlib.patches import Ellipse\n",
    "import matplotlib.transforms as transforms\n",
    "\n",
    "def confidence_ellipse(x, y, ax, n_std=1.5, **kwargs):\n",
    "    cov = np.cov(x, y)\n",
    "    pearson = cov[0, 1] / np.sqrt(cov[0, 0] * cov[1, 1])\n",
    "    rx, ry = np.sqrt(1 + pearson), np.sqrt(1 - pearson)\n",
    "    ellipse = Ellipse((0, 0), width=rx * 2, height=ry * 2, **kwargs)\n",
    "    scale_x = np.sqrt(cov[0, 0]) * n_std\n",
    "    scale_y = np.sqrt(cov[1, 1]) * n_std\n",
    "    transf = transforms.Affine2D() \\\n",
    "        .rotate_deg(45) \\\n",
    "        .scale(scale_x, scale_y) \\\n",
    "        .translate(np.mean(x), np.mean(y))\n",
    "    ellipse.set_transform(transf + ax.transData)\n",
    "    ax.add_patch(ellipse)\n",
    "\n",
    "for condition in ['Cancer', 'Infection']:\n",
    "    mask = conditions == condition\n",
    "    confidence_ellipse(\n",
    "        pca_coords[mask, 0], pca_coords[mask, 1], ax,\n",
    "        n_std=1.5,\n",
    "        facecolor=palette[condition],\n",
    "        alpha=0.08,\n",
    "        edgecolor=palette[condition],\n",
    "        linewidth=1.2,\n",
    "        linestyle='--'\n",
    "    )\n",
    "\n",
    "ax.set_xlabel(f'PC1 ({var_explained[0]:.1f}% variance)', fontsize=12)\n",
    "ax.set_ylabel(f'PC2 ({var_explained[1]:.1f}% variance)', fontsize=12)\n",
    "ax.set_title('PCA — Lung Cancer vs. Pulmonary Infection\\nBALF RNA-seq (GSE252118)', \n",
